@model PharmaSmartWeb.Models.Shifts

@{
    ViewData["Title"] = "إغلاق الوردية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border-start border-5 border-danger">
                <div>
                    <h4 class="mb-1 fw-bold text-dark"><i class="material-symbols-outlined align-middle fs-3 text-danger me-2">lock_clock</i> إغلاق الوردية الحالية</h4>
                    <p class="text-muted mb-0 small">مطابقة الصندوق وإنهاء أعمال الكاشير للوردية المفتوحة منذ: <span class="fw-bold" dir="ltr">@Model.OpenedAt.ToString("dd/MM/yyyy hh:mm tt")</span></p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">ملخص الحركات (أثناء الوردية)</h5>
                    <div class="row g-4">
                        <div class="col-sm-6 col-md-3">
                            <div class="p-3 bg-light rounded-3 text-center border">
                                <span class="d-block text-muted small mb-1">العهدة المبدئية</span>
                                <h4 class="fw-bold text-dark mb-0">@Model.OpeningBalance.ToString("N2")</h4>
                            </div>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <div class="p-3 bg-success bg-opacity-10 rounded-3 text-center border border-success">
                                <span class="d-block text-success small mb-1">المبيعات النقدية</span>
                                <h4 class="fw-bold text-success mb-0">@ViewBag.TotalCash.ToString("N2")</h4>
                            </div>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <div class="p-3 bg-danger bg-opacity-10 rounded-3 text-center border border-danger">
                                <span class="d-block text-danger small mb-1">المرتجعات النقدية</span>
                                <h4 class="fw-bold text-danger mb-0">@ViewBag.TotalReturns.ToString("N2")</h4>
                            </div>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <div class="p-3 bg-primary bg-opacity-10 rounded-3 text-center border border-primary">
                                <span class="d-block text-primary small mb-1">صافي الكاش المتوقع</span>
                                <h4 class="fw-bold text-primary mb-0">@Model.ExpectedCash.ToString("N2")</h4>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />
                    
                    <h5 class="fw-bold mb-3 text-secondary">عمليات غير نقدية (للعلم فقط)</h5>
                    <div class="d-flex gap-4">
                        <div>
                            <span class="text-muted small">إجمالي المبيعات (نقد + شبكة):</span>
                            <span class="fw-bold ms-1">@ViewBag.TotalSales.ToString("N2")</span>
                        </div>
                        <div>
                            <span class="text-muted small">مدفوعات البنك/الشبكة:</span>
                            <span class="fw-bold ms-1">@ViewBag.TotalBank.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-danger text-white text-center rounded-top-4 py-3">
                    <h5 class="mb-0 fw-bold">مطابقة الصندوق</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ConfirmClose" method="post" id="closeShiftForm">
                        <input type="hidden" name="ShiftId" value="@Model.ShiftId" />
                        
                        <div class="form-group mb-4">
                            <label class="form-label fw-bold text-dark">النقد الفعلي بالدرج (Actual Cash)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="material-symbols-outlined">account_balance_wallet</i></span>
                                <input type="number" step="0.01" name="ActualCash" id="ActualCash" class="form-control text-center fw-bold fs-4" required placeholder="0.00" />
                            </div>
                            <small class="text-muted mt-2 d-block">قم بعدّ النقود الموجودة في الدرج وأدخلها هنا.</small>
                        </div>

                        <div class="form-group mb-4 text-center p-3 rounded-3" id="diffContainer" style="background-color:#f8f9fa;">
                            <span class="d-block text-muted mb-1">الفرق (عجز / زيادة)</span>
                            <h3 class="fw-bold mb-0" id="diffAmount" dir="ltr">0.00</h3>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold" onclick="return confirm('هل أنت متأكد من إغلاق الوردية؟ لا يمكن التراجع عن هذا الإجراء وسيتم تصفير العدادات للوردية القادمة.')">
                                <i class="material-symbols-outlined align-middle me-1">lock</i> اعتماد الإغلاق وتسليم العهدة
                            </button>
                            <a href="/Sales/Index" class="btn btn-light fw-bold">تراجع</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var expected = @Model.ExpectedCash;
            
            $('#ActualCash').on('input', function() {
                var actual = parseFloat($(this).val()) || 0;
                var diff = actual - expected;
                
                var diffEl = $('#diffAmount');
                var container = $('#diffContainer');
                
                diffEl.text(diff.toFixed(2));
                
                if(diff < 0) {
                    diffEl.removeClass('text-success text-secondary').addClass('text-danger');
                    container.css('background-color', '#fff5f5');
                    container.css('border', '1px solid #dc3545');
                } else if(diff > 0) {
                    diffEl.removeClass('text-danger text-secondary').addClass('text-success');
                    container.css('background-color', '#f0fdf4');
                    container.css('border', '1px solid #198754');
                } else {
                    diffEl.removeClass('text-danger text-success').addClass('text-secondary');
                    container.css('background-color', '#f8f9fa');
                    container.css('border', 'none');
                }
            });
        });
    </script>
}
