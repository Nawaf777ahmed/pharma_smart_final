@model PharmaSmartWeb.Models.Shifts

@{
    ViewData["Title"] = "فتح وردية جديدة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid p-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4 py-3">
                    <h4 class="mb-0 fw-bold"><i class="material-symbols-outlined align-middle fs-3 me-2">point_of_sale</i>فتح وردية جديدة</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="OpenShift" method="post">
                        <div class="text-center mb-4">
                            <p class="text-muted">الرجاء إدخال المبلغ الموجود حالياً في درج الكاشير قبل بدء المبيعات.</p>
                        </div>
                        
                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">العهدة المبدئية (رصيد الدرج الافتتاحي)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light"><i class="material-symbols-outlined">payments</i></span>
                                <input asp-for="OpeningBalance" type="number" step="0.01" min="0" class="form-control text-center fw-bold fs-4 text-success" required />
                                <span class="input-group-text bg-light">YER</span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">ملاحظات (اختياري)</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="أي ملاحظات حول العهدة الافتتاحية..."></textarea>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                <i class="material-symbols-outlined align-middle me-2">check_circle</i> اعتماد وفتح الوردية
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
