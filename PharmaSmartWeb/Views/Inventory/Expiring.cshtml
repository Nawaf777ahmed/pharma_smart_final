@inject PharmaSmartWeb.Services.ISystemSettingsService Settings
@model IEnumerable<PharmaSmartWeb.Models.DrugBatches>

@{
    Layout = "_ReportLayout";
    ViewData["Title"] = "تقرير الأدوية قريبة الانتهاء";
    ViewData["Subtitle"] = "EXPIRING DRUGS REPORT";
    ViewData["PageDescription"] = "متابعة صلاحية الأدوية والباتشات قريبة الانتهاء في المخزون.";
    
    // Default info for _ReportLayout summary box
    ViewBag.ReportNumber = "EXP-" + DateTime.Now.ToString("yyyyMMdd-HHmm");
    ViewBag.ReportPeriod = "التاريخ والإحصاء اللحظي";
    ViewBag.ReportNotes = "تقرير يوضح الدفعات المهددة بالانتهاء قريباً.";
    ViewBag.ReportBranchName = ViewBag.BranchName ?? "الفرع الرئيسي";

    var expiredCount = Model.Count(x => x.ExpiryDate < DateTime.Today);
    var expiringSoonCount = Model.Count(x => x.ExpiryDate >= DateTime.Today && x.ExpiryDate <= DateTime.Today.AddMonths(2));
}

@section Summary {
    <div><span>إجمالي الدفعات المهددة:</span><span style="font-weight:bold;">@Model.Count()</span></div>
    <div><span style="color:#e11d48;">منتهية الصلاحية:</span><span style="color:#e11d48; font-weight:bold;">@expiredCount</span></div>
    <div><span style="color:#d97706;">تنتهي قريباً:</span><span style="color:#d97706; font-weight:bold;">@expiringSoonCount</span></div>
}

@section Styles {
    <style>
        .badge-critical { background: #fef2f2; color: #e11d48; border: 1px solid #fecdd3; padding: 2px 8px; font-size: 11px; font-weight: bold; border-radius: 2px; display: inline-flex; align-items: center; gap: 4px; }
        .badge-warning { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; padding: 2px 8px; font-size: 11px; font-weight: bold; border-radius: 2px; display: inline-flex; align-items: center; gap: 4px; }
        
        .kpi-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 20px; }
        .kpi-card { border: 1px solid #e2e8f0; padding: 14px; text-align: center; background: white; border-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        
        .report-table { width: 100%; border-collapse: collapse; margin-top: 10px; background: white; border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden; }
        .report-table th { background: #f8fafc; border-bottom: 2px solid #cbd5e1; padding: 10px; font-size: 12px; font-weight: bold; color: #334155; }
        .report-table td { padding: 10px; border-bottom: 1px solid #e2e8f0; font-size: 13px; color: #1e293b; vertical-align: middle; }
    </style>
}

<!-- KPI Row -->
<div class="kpi-row">
    <div class="kpi-card" style="border-top:3px solid #063955;">
        <div style="font-size:11px; color:#64748b; font-weight:bold;">إجمالي الدفعات المهددة</div>
        <div style="font-size:26px; font-weight:900; color:#063955; font-family:monospace;">@Model.Count()</div>
    </div>
    <div class="kpi-card" style="border-top:3px solid #e11d48;">
        <div style="font-size:11px; color:#64748b; font-weight:bold;">أدوية منتهية الصلاحية تماماً</div>
        <div style="font-size:26px; font-weight:900; color:#e11d48; font-family:monospace;">@expiredCount</div>
    </div>
    <div class="kpi-card" style="border-top:3px solid #d97706;">
        <div style="font-size:11px; color:#64748b; font-weight:bold;">تنتهي خلال شهرين</div>
        <div style="font-size:26px; font-weight:900; color:#d97706; font-family:monospace;">@expiringSoonCount</div>
    </div>
</div>

<!-- Data Table -->
<div class="bg-white p-4 rounded-sm border border-slate-200 shadow-sm">
    <h3 style="font-size:14px; font-weight:bold; color:#d97706; margin-bottom:12px; border-bottom: 1px solid #fde68a; padding-bottom: 8px;">قائمة الأدوية وتاريخ الصلاحية</h3>

    <div class="overflow-x-auto">
        <table class="report-table">
            <thead>
                <tr>
                    <th style="width:40px; text-align:center;">#</th>
                    <th style="text-align:right;">اسم الدواء / الصنف</th>
                    <th style="text-align:center;">رقم التشغيلة (Batch)</th>
                    <th style="text-align:center;">تاريخ الانتهاء</th>
                    <th style="width: 180px; text-align:center;">الحالة</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="padding: 40px; text-align: center;">
                            <span style="font-size: 32px; color: #059669;">✓</span>
                            <h3 style="font-size: 14px; font-weight: bold; color: #059669; margin-top: 8px;">ممتاز! لا توجد أدوية قريبة الانتهاء في هذا النطاق.</h3>
                        </td>
                    </tr>
                }
                else
                {
                    int r = 1;
                    foreach (var item in Model)
                    {
                        var isExpired = item.ExpiryDate < DateTime.Today;
                        var daysRemaining = (item.ExpiryDate - DateTime.Today).Days;
                        
                        <tr>
                            <td style="text-align:center;">@r</td>
                            <td style="text-align:right;">
                                <span style="font-weight:bold; color:#063955; font-size:13px;">@item.Drug?.DrugName</span><br/>
                                <span style="font-family:monospace; font-size:10px; color:#94a3b8; font-weight:bold;">كود: #@item.DrugId.ToString("D4")</span>
                            </td>
                            <td style="text-align:center; font-family:monospace; font-weight:bold; color:#475569;">
                                @item.BatchNumber
                            </td>
                            <td style="text-align:center; font-family:monospace; font-weight:900; color:@(isExpired ? "#e11d48" : "#d97706"); font-size: 14px;">
                                @item.ExpiryDate.ToString("yyyy-MM-dd")
                            </td>
                            <td style="text-align:center;">
                                @if(isExpired)
                                {
                                    <span class="badge-critical">⚠️ منتهية الصلاحية</span>
                                }
                                else
                                {
                                    <span class="badge-warning">⏳ باق @daysRemaining يوم</span>
                                }
                            </td>
                        </tr>
                        r++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>
